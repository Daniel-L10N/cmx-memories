{
  "name": "cmx-memories",
  "version": "1.0.0",
  "description": "Local-first personal memory system with SQLite + hybrid search for AI agents",
  "author": "Daniel L10N <Daniel-L10N@github.com>",
  "license": "MIT",
  "homepage": "https://github.com/Daniel-L10N/cmx-memories",
  "repository": {
    "type": "git",
    "url": "https://github.com/Daniel-L10N/cmx-memories"
  },
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "cmx-memories": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "api": "tsx src/api/index.ts",
    "api:remote": "tsx src/api/index.ts 3000 0.0.0.0",
    "api:subpath": "CMX_BASE_PATH=/cmx-memories tsx src/api/index.ts",
    "api:subpath:remote": "CMX_BASE_PATH=/cmx-memories tsx src/api/index.ts 3000 0.0.0.0",
    "api:build": "tsc -p tsconfig.api.json",
    "api:start": "node dist/api/index.js",
    "api:start:subpath": "CMX_BASE_PATH=/cmx-memories node dist/api/index.js",
    "mcp": "tsx src/mcp/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "mcp:remote": "MCP_MODE=http MCP_BASE_PATH=/cmx-memories tsx src/mcp/index.ts"
  },
  "keywords": [
    "memory",
    "notes",
    "sqlite",
    "local-first",
    "cli"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.6.0",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.39.1",
    "express": "^5.2.1",
    "uuid": "^13.0.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.2",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.30.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
