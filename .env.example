# cmx-memories Environment Configuration
# Copy this file to .env and customize

# ============================================
# Server Configuration
# ============================================
CMX_API_PORT=3000
CMX_API_HOST=0.0.0.0

# ============================================
# Security
# ============================================
# IMPORTANT: Change this to a secure key in production!
CMX_API_KEY=cmx-dev-key

# ============================================
# Base Path (for reverse proxy deployments)
# ============================================
# Uncomment for subpath deployment:
# CMX_BASE_PATH=/cmx-memories

# ============================================
# Database (optional overrides)
# ============================================
# CMX_DB_PATH=./memories.db
